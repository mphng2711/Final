# ============================================================
# PURE PAW WEB - Server Environment Variables
# Copy file này thành .env và thay đổi giá trị cho phù hợp
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/purepaw_db

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_this
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CLIENT_URL=http://localhost:4200

# Upload (Multer)
UPLOAD_MAX_SIZE=5242880
