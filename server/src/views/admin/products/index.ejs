<% locals.activePage = 'products' %>

<div class="page-header">
    <h1>📦 Quản lý sản phẩm (<%= total %>)</h1>
    <a href="/admin/san-pham/them-moi" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm sản phẩm</a>
</div>

<!-- Filter -->
<div class="card" style="margin-bottom:20px">
    <form method="GET" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end">
        <div><label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">TÌM KIẾM</label>
        <input type="text" name="search" class="form-control" placeholder="Tên sản phẩm..." value="<%= query.search||'' %>" style="width:200px"></div>
        <div><label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">DANH MỤC</label>
        <select name="category" class="form-control">
            <option value="">Tất cả</option>
            <% categories.forEach(c => { %><option value="<%= c._id %>" <%= query.category===c._id.toString()?'selected':'' %>><%= c.name %></option><% }) %>
        </select></div>
        <div><label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">TRẠNG THÁI</label>
        <select name="status" class="form-control">
            <option value="">Tất cả</option>
            <option value="active" <%= query.status==='active'?'selected':'' %>>Hoạt động</option>
            <option value="inactive" <%= query.status==='inactive'?'selected':'' %>>Ẩn</option>
        </select></div>
        <button type="submit" class="btn btn-primary" style="height:38px">🔍 Lọc</button>
        <a href="/admin/san-pham" class="btn btn-secondary" style="height:38px;display:inline-flex;align-items:center">Xóa lọc</a>
    </form>
</div>

<!-- Table -->
<div class="card">
    <table>
        <thead><tr><th>Sản phẩm</th><th>Danh mục</th><th>Giá</th><th>Kho</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
        <tbody>
        <% if (products.length) { %>
        <% products.forEach(p => { %>
        <tr>
            <td style="max-width:220px">
                <div style="display:flex;align-items:center;gap:10px">
                    <img src="<%= p.thumbnail||'/assets/Image.png' %>" style="width:45px;height:45px;object-fit:cover;border-radius:6px;background:#f5f5f5" onerror="this.src='/assets/Image.png'">
                    <div>
                        <p style="font-weight:600;font-size:14px;line-height:1.3"><%= p.name %></p>
                        <% if(p.isFeatured){%><span style="font-size:11px;color:#FFB606;font-weight:600">⭐ Nổi bật</span><%}%>
                    </div>
                </div>
            </td>
            <td style="font-size:13px;color:#666"><%= p.category ? p.category.name : '—' %></td>
            <td style="font-weight:600;color:#FFB606">
                <% if(p.variants&&p.variants[0]){%><%= (p.variants[0].salePrice||p.variants[0].price).toLocaleString('vi-VN') %>₫<%}else{%>—<%}%>
            </td>
            <td style="font-size:13px"><%= p.variants ? p.variants.reduce((s,v)=>s+v.stock,0) : 0 %></td>
            <td>
                <span class="badge <%= p.isActive?'badge-success':'badge-secondary' %>"><%= p.isActive?'Hoạt động':'Ẩn' %></span>
            </td>
            <td>
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <a href="/admin/san-pham/<%= p._id %>/sua" class="btn btn-secondary btn-sm">✏️ Sửa</a>
                    <form action="/admin/san-pham/<%= p._id %>/toggle?_method=PATCH" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-sm" style="background:<%= p.isActive?'#6c757d':'#28a745' %>;color:#fff"><%= p.isActive?'Ẩn':'Hiện' %></button>
                    </form>
                    <form action="/admin/san-pham/<%= p._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Xóa sản phẩm này?')">
                        <button type="submit" class="btn btn-danger btn-sm">🗑</button>
                    </form>
                </div>
            </td>
        </tr>
        <% }) %>
        <% } else { %>
        <tr><td colspan="6" style="text-align:center;padding:40px;color:#999">Không có sản phẩm nào</td></tr>
        <% } %>
        </tbody>
    </table>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
        <% if (page > 1) { %><a href="?page=<%= page-1 %>">← Trước</a><% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === page) { %><span class="current"><%= i %></span><% } else { %><a href="?page=<%= i %>"><%= i %></a><% } %>
        <% } %>
        <% if (page < totalPages) { %><a href="?page=<%= page+1 %>">Tiếp →</a><% } %>
    </div>
    <% } %>
</div>
