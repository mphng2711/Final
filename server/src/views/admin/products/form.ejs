<% locals.activePage = 'products' %>

<style>
.img-upload-area {
  border: 2.5px dashed #e0e0e0;
  border-radius: 12px;
  padding: 22px;
  text-align: center;
  cursor: pointer;
  transition: all .25s;
  background: #fafafa;
  position: relative;
}
.img-upload-area:hover, .img-upload-area.drag-over {
  border-color: #FFB606;
  background: #fffbeb;
}
.img-upload-area input[type=file] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
.thumb-preview {
  width: 140px; height: 140px; object-fit: cover;
  border-radius: 10px; border: 3px solid #FFE002;
  display: block; margin: 0 auto 12px;
  box-shadow: 0 4px 14px rgba(0,0,0,.12);
}
.gallery-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 10px; margin-top: 12px;
}
.gallery-item {
  position: relative; border-radius: 8px; overflow: hidden;
  border: 2px solid #e0e0e0;
}
.gallery-item img { width: 100%; height: 90px; object-fit: cover; display: block; }
.gallery-item .remove-layer {
  position: absolute; top: 4px; right: 4px;
  background: rgba(220,53,69,.85); color: #fff;
  border: none; border-radius: 50%; width: 22px; height: 22px;
  font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center;
}
.gallery-item .keep-check {
  position: absolute; bottom: 4px; left: 4px;
  accent-color: #FFB606; width: 16px; height: 16px; cursor: pointer;
}
.variant-row {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr auto;
  gap: 8px; align-items: end; margin-bottom: 10px;
  padding: 12px; background: #f9f9f9; border-radius: 8px;
}
@media(max-width:768px) {
  .variant-row { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="page-header">
  <h1><%= product ? '✏️ Sửa sản phẩm' : '➕ Thêm sản phẩm mới' %></h1>
  <a href="/admin/san-pham" class="btn btn-secondary">← Quay lại</a>
</div>

<form action="<%= product ? `/admin/san-pham/${product._id}?_method=PUT` : '/admin/san-pham' %>"
      method="POST" enctype="multipart/form-data" id="productForm">

<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px">

  <!-- ═══ LEFT ═══════════════════════════════════════════════ -->
  <div>

    <!-- Thông tin cơ bản -->
    <div class="card">
      <h3 style="margin-bottom:18px;font-size:16px;color:#555;border-bottom:1px solid #f0f0f0;padding-bottom:10px">📝 Thông tin cơ bản</h3>
      <div class="form-group">
        <label class="form-label">Tên sản phẩm *</label>
        <input type="text" name="name" class="form-control" required
               value="<%= product ? product.name : '' %>" placeholder="Tên sản phẩm">
      </div>
      <div class="form-group">
        <label class="form-label">Mô tả ngắn</label>
        <textarea name="shortDescription" class="form-control" rows="2"
                  placeholder="Hiển thị trên card sản phẩm (tối đa 300 ký tự)"><%= product && product.shortDescription ? product.shortDescription : '' %></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Mô tả đầy đủ *</label>
        <textarea name="description" class="form-control" rows="7" required
                  placeholder="Mô tả chi tiết sản phẩm..."><%= product ? product.description : '' %></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Tags (phân cách bằng dấu phẩy)</label>
        <input type="text" name="tags" class="form-control"
               value="<%= product && product.tags ? product.tags.join(', ') : '' %>"
               placeholder="thức ăn, chó, dinh dưỡng">
      </div>
    </div>

    <!-- Ảnh thumbnail -->
    <div class="card">
      <h3 style="margin-bottom:18px;font-size:16px;color:#555;border-bottom:1px solid #f0f0f0;padding-bottom:10px">🖼 Ảnh đại diện (Thumbnail) *</h3>
      <div class="img-upload-area" id="thumbArea" onclick="document.getElementById('thumbInput').click()">
        <input type="file" name="thumbnail" id="thumbInput" accept="image/*"
               style="display:none" onchange="previewThumb(event)">
        <% if (product && product.thumbnail) { %>
          <img id="thumbPreview" src="<%= product.thumbnail %>"
               class="thumb-preview" onerror="this.src='/assets/placeholder.png'">
          <p style="color:#999;font-size:13px">📷 Click hoặc kéo ảnh vào đây để thay đổi</p>
        <% } else { %>
          <img id="thumbPreview" src="" class="thumb-preview" style="display:none">
          <div id="thumbPlaceholder">
            <div style="font-size:42px;margin-bottom:8px">📷</div>
            <p style="font-weight:600;color:#555;margin-bottom:4px">Click hoặc kéo ảnh vào đây</p>
            <p style="color:#999;font-size:13px">PNG, JPG, WEBP – tối đa 5MB</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Gallery ảnh -->
    <div class="card">
      <h3 style="margin-bottom:18px;font-size:16px;color:#555;border-bottom:1px solid #f0f0f0;padding-bottom:10px">
        🖼 Ảnh thư viện (tối đa 8 ảnh)
        <span style="font-weight:400;font-size:12px;color:#999"> — để trống = giữ nguyên ảnh cũ</span>
      </h3>

      <!-- Ảnh gallery hiện tại -->
      <% if (product && product.images && product.images.length) { %>
      <p style="font-size:13px;font-weight:600;margin-bottom:8px;color:#555">✅ Ảnh hiện tại (bỏ tick để xóa):</p>
      <div class="gallery-grid" id="existingGallery">
        <% product.images.forEach((img, idx) => { %>
        <div class="gallery-item" id="existing-<%= idx %>">
          <img src="<%= img %>" onerror="this.src='/assets/placeholder.png'" alt="">
          <input type="checkbox" name="keepImages" value="<%= img %>"
                 class="keep-check" checked title="Giữ ảnh này"
                 onchange="toggleRemoveOverlay(this, 'existing-<%= idx %>')">
        </div>
        <% }) %>
      </div>
      <% } %>

      <!-- Upload ảnh mới -->
      <div style="margin-top:14px">
        <p style="font-size:13px;font-weight:600;margin-bottom:8px;color:#555">➕ Thêm ảnh mới:</p>
        <div class="img-upload-area" id="galleryArea" onclick="document.getElementById('galleryInput').click()">
          <input type="file" name="images" id="galleryInput" accept="image/*"
                 multiple style="display:none" onchange="previewGallery(event)">
          <div id="galleryPlaceholder">
            <div style="font-size:36px;margin-bottom:6px">🗂</div>
            <p style="font-weight:600;color:#555;margin-bottom:4px">Chọn nhiều ảnh</p>
            <p style="color:#999;font-size:12px">Giữ Ctrl để chọn nhiều file</p>
          </div>
        </div>
        <div class="gallery-grid" id="newGalleryPreview"></div>
      </div>
    </div>

    <!-- Variants -->
    <div class="card">
      <h3 style="margin-bottom:18px;font-size:16px;color:#555;border-bottom:1px solid #f0f0f0;padding-bottom:10px">
        📦 Phân loại & Giá
        <button type="button" onclick="addVariant()" class="btn btn-secondary btn-sm" style="float:right">+ Thêm phân loại</button>
      </h3>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr auto;gap:8px;font-size:12px;font-weight:700;color:#777;padding:0 4px;margin-bottom:6px">
        <span>Tên phân loại</span><span>Giá gốc (₫)</span><span>Giá KM (₫)</span><span>SKU</span><span>Tồn kho</span><span></span>
      </div>
      <div id="variantContainer">
        <% if (product && product.variants && product.variants.length) { %>
          <% product.variants.forEach((v, i) => { %>
          <div class="variant-row" id="variant-<%= i %>">
            <input type="text" name="variants[<%= i %>][name]" class="form-control" required
                   value="<%= v.name %>" placeholder="VD: Gói 1kg">
            <input type="number" name="variants[<%= i %>][price]" class="form-control" required
                   value="<%= v.price %>" min="0" placeholder="150000">
            <input type="number" name="variants[<%= i %>][salePrice]" class="form-control"
                   value="<%= v.salePrice || '' %>" min="0" placeholder="KM">
            <input type="text" name="variants[<%= i %>][sku]" class="form-control"
                   value="<%= v.sku %>" placeholder="SKU-001">
            <input type="number" name="variants[<%= i %>][stock]" class="form-control" required
                   value="<%= v.stock %>" min="0">
            <button type="button" onclick="removeVariant(<%= i %>)"
                    class="btn btn-danger btn-sm" title="Xóa">🗑</button>
          </div>
          <% }) %>
        <% } else { %>
          <div class="variant-row" id="variant-0">
            <input type="text" name="variants[0][name]" class="form-control" required value="Mặc định" placeholder="VD: Gói 1kg">
            <input type="number" name="variants[0][price]" class="form-control" required value="" min="0" placeholder="150000">
            <input type="number" name="variants[0][salePrice]" class="form-control" min="0" placeholder="KM">
            <input type="text" name="variants[0][sku]" class="form-control" placeholder="SKU-001">
            <input type="number" name="variants[0][stock]" class="form-control" required value="0" min="0">
            <button type="button" onclick="removeVariant(0)" class="btn btn-danger btn-sm">🗑</button>
          </div>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ═══ RIGHT (Sidebar) ════════════════════════════════════ -->
  <div>
    <div class="card">
      <h3 style="margin-bottom:15px;font-size:16px;color:#555;border-bottom:1px solid #f0f0f0;padding-bottom:10px">📂 Phân loại</h3>
      <div class="form-group">
        <label class="form-label">Danh mục *</label>
        <select name="category" class="form-control" required>
          <option value="">Chọn danh mục</option>
          <% categories.forEach(c => { %>
          <option value="<%= c._id %>"
            <%= product && product.category && product.category.toString() === c._id.toString() ? 'selected' : '' %>>
            <%= c.name %>
          </option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Loài thú cưng</label>
        <select name="petType" class="form-control">
          <option value="">Không chỉ định</option>
          <option value="dog" <%= product && product.petType === 'dog' ? 'selected' : '' %>>🐶 Chó</option>
          <option value="cat" <%= product && product.petType === 'cat' ? 'selected' : '' %>>🐱 Mèo</option>
          <option value="other" <%= product && product.petType === 'other' ? 'selected' : '' %>>🐹 Khác</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Thương hiệu</label>
        <input type="text" name="brand" class="form-control"
               value="<%= product && product.brand ? product.brand : '' %>"
               placeholder="Royal Canin, Whiskas...">
      </div>
    </div>

    <div class="card">
      <h3 style="margin-bottom:15px;font-size:16px;color:#555;border-bottom:1px solid #f0f0f0;padding-bottom:10px">⚙️ Cài đặt</h3>
      <div class="form-check" style="margin-bottom:12px">
        <input type="checkbox" name="isActive" id="isActive"
               <%= !product || product.isActive ? 'checked' : '' %>>
        <label for="isActive" style="font-weight:600;font-size:14px">✅ Kích hoạt (hiển thị)</label>
      </div>
      <div class="form-check">
        <input type="checkbox" name="isFeatured" id="isFeatured"
               <%= product && product.isFeatured ? 'checked' : '' %>>
        <label for="isFeatured" style="font-weight:600;font-size:14px">⭐ Nổi bật (trang chủ)</label>
      </div>
    </div>

    <!-- Ảnh preview nhanh -->
    <div class="card" id="currentThumbCard" style="<%= product && product.thumbnail ? '' : 'display:none' %>">
      <h3 style="margin-bottom:12px;font-size:14px;color:#555">👁 Ảnh hiện tại</h3>
      <img id="currentThumbDisplay"
           src="<%= product && product.thumbnail ? product.thumbnail : '' %>"
           style="width:100%;border-radius:8px;border:2px solid #f0f0f0"
           onerror="this.src='/assets/placeholder.png'">
    </div>

    <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;font-size:15px;margin-top:8px">
      💾 <%= product ? 'Cập nhật sản phẩm' : 'Tạo sản phẩm' %>
    </button>
    <a href="/admin/san-pham" class="btn btn-secondary" style="width:100%;text-align:center;margin-top:8px;padding:12px">
      ✕ Hủy
    </a>
  </div>

</div>
</form>

<script>
// ── Thumbnail preview ────────────────────────────────────────
function previewThumb(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const img = document.getElementById('thumbPreview');
    const holder = document.getElementById('thumbPlaceholder');
    img.src = ev.target.result;
    img.style.display = 'block';
    if (holder) holder.style.display = 'none';

    // Cập nhật ảnh "hiện tại" ở sidebar
    const card = document.getElementById('currentThumbCard');
    const display = document.getElementById('currentThumbDisplay');
    if (card) card.style.display = 'block';
    if (display) display.src = ev.target.result;
  };
  reader.readAsDataURL(file);
}

// ── Gallery preview ──────────────────────────────────────────
function previewGallery(e) {
  const files = Array.from(e.target.files);
  const container = document.getElementById('newGalleryPreview');
  const placeholder = document.getElementById('galleryPlaceholder');
  if (placeholder) placeholder.style.display = files.length ? 'none' : 'block';

  container.innerHTML = '';
  files.forEach((file, idx) => {
    const reader = new FileReader();
    reader.onload = ev => {
      const div = document.createElement('div');
      div.className = 'gallery-item';
      div.innerHTML = `
        <img src="${ev.target.result}" alt="" style="width:100%;height:90px;object-fit:cover">
        <span style="position:absolute;bottom:4px;left:4px;background:rgba(0,0,0,.6);color:#fff;font-size:10px;padding:2px 5px;border-radius:4px">${idx + 1}</span>`;
      container.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
}

// ── Toggle xóa ảnh gallery cũ ────────────────────────────────
function toggleRemoveOverlay(checkbox, itemId) {
  const item = document.getElementById(itemId);
  if (!item) return;
  item.style.opacity = checkbox.checked ? '1' : '0.35';
  item.style.border = checkbox.checked ? '2px solid #e0e0e0' : '2px solid #dc3545';
}

// ── Drag & drop trên cả hai upload area ───────────────────────
['thumbArea', 'galleryArea'].forEach(id => {
  const area = document.getElementById(id);
  if (!area) return;
  area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('drag-over'); });
  area.addEventListener('dragleave', () => area.classList.remove('drag-over'));
  area.addEventListener('drop', e => {
    e.preventDefault();
    area.classList.remove('drag-over');
    const inputId = id === 'thumbArea' ? 'thumbInput' : 'galleryInput';
    const input = document.getElementById(inputId);
    const dt = new DataTransfer();
    Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
    input.files = dt.files;
    input.dispatchEvent(new Event('change'));
  });
});

// ── Dynamic variants ──────────────────────────────────────────
let variantCount = document.querySelectorAll('[id^="variant-"]').length;

function addVariant() {
  const i = variantCount++;
  const div = document.createElement('div');
  div.className = 'variant-row';
  div.id = `variant-${i}`;
  div.innerHTML = `
    <input type="text"   name="variants[${i}][name]"      class="form-control" required placeholder="VD: Gói 2kg">
    <input type="number" name="variants[${i}][price]"     class="form-control" required min="0" placeholder="200000">
    <input type="number" name="variants[${i}][salePrice]" class="form-control" min="0" placeholder="KM">
    <input type="text"   name="variants[${i}][sku]"       class="form-control" placeholder="SKU-00${i}">
    <input type="number" name="variants[${i}][stock]"     class="form-control" required value="0" min="0">
    <button type="button" onclick="removeVariant(${i})" class="btn btn-danger btn-sm">🗑</button>`;
  document.getElementById('variantContainer').appendChild(div);
}

function removeVariant(i) {
  const rows = document.querySelectorAll('[id^="variant-"]');
  if (rows.length <= 1) { alert('Sản phẩm phải có ít nhất 1 phân loại!'); return; }
  const el = document.getElementById(`variant-${i}`);
  if (el) el.remove();
}
</script>
