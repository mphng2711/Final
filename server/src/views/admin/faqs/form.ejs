<% locals.activePage = 'faqs' %>

<div class="page-header">
  <h1><%= faq ? '✏️ Sửa câu hỏi' : '➕ Thêm câu hỏi mới' %></h1>
</div>

<div class="card" style="max-width:700px">
  <form action="<%= faq ? '/admin/faq/'+faq._id+'?_method=PUT' : '/admin/faq' %>" method="POST">
    <div class="form-group">
      <label class="form-label">Câu hỏi *</label>
      <textarea name="question" class="form-control" required rows="2"
                placeholder="Câu hỏi thường gặp..."><%= faq ? faq.question : '' %></textarea>
    </div>
    <div class="form-group">
      <label class="form-label">Câu trả lời *</label>
      <textarea name="answer" class="form-control" required rows="5"
                placeholder="Câu trả lời chi tiết..."><%= faq ? faq.answer : '' %></textarea>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
      <div class="form-group">
        <label class="form-label">Danh mục</label>
        <select name="category" class="form-control">
          <% categories.forEach(c => { %>
          <option value="<%= c %>" <%= faq && faq.category===c ? 'selected':'' %>><%= categoryLabels[c] %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Thứ tự sắp xếp</label>
        <input type="number" name="sortOrder" class="form-control" min="0"
               value="<%= faq ? faq.sortOrder : 0 %>">
      </div>
      <div class="form-group">
        <label class="form-label">Trạng thái</label>
        <div style="display:flex;align-items:center;gap:8px;padding:10px 0">
          <input type="checkbox" name="isActive" id="isActive"
                 <%= !faq || faq.isActive ? 'checked' : '' %> style="width:18px;height:18px">
          <label for="isActive" style="font-weight:600">Hiển thị</label>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:12px;margin-top:8px">
      <button type="submit" class="btn btn-primary"><%= faq ? '💾 Cập nhật' : '✅ Tạo câu hỏi' %></button>
      <a href="/admin/faq" class="btn btn-secondary">← Quay lại</a>
    </div>
  </form>
</div>
