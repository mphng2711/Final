<% locals.activePage = 'orders' %>

<div class="page-header">
    <h1>🛒 Quản lý đơn hàng (<%= total %>)</h1>
</div>

<div class="card" style="margin-bottom:20px">
    <form method="GET" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end">
        <div><label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">TÌM MÃ ĐƠN</label>
        <input type="text" name="search" class="form-control" placeholder="PP-20260317-..." value="<%= query.search||'' %>" style="width:180px"></div>
        <div><label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">TRẠNG THÁI</label>
        <select name="status" class="form-control">
            <option value="">Tất cả</option>
            <% statuses.forEach(s => { %><option value="<%= s %>" <%= query.status===s?'selected':'' %>><%= statusLabels[s] %></option><% }) %>
        </select></div>
        <button type="submit" class="btn btn-primary">🔍</button>
        <a href="/admin/don-hang" class="btn btn-secondary">Xóa lọc</a>
    </form>
</div>

<div class="card">
    <table>
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày đặt</th><th>Thao tác</th></tr></thead>
        <tbody>
        <% if (orders.length) { %>
        <% orders.forEach(o => { %>
        <tr>
            <td><a href="/admin/don-hang/<%= o._id %>" style="color:#FFB606;font-weight:600;text-decoration:none"><%= o.orderCode %></a></td>
            <td><%= o.user?o.user.fullName:'N/A' %><br><span style="font-size:12px;color:#999"><%= o.user?o.user.email:'' %></span></td>
            <td style="font-weight:700;color:#FFB606"><%= o.totalAmount.toLocaleString('vi-VN') %>₫</td>
            <td><span class="badge <%= {pending:'badge-warning',confirmed:'badge-info',processing:'badge-info',shipping:'badge-info',delivered:'badge-success',cancelled:'badge-danger',returned:'badge-secondary'}[o.status]||'badge-secondary' %>"><%= statusLabels[o.status]||o.status %></span></td>
            <td style="font-size:13px;color:#666"><%= new Date(o.createdAt).toLocaleDateString('vi-VN') %></td>
            <td><a href="/admin/don-hang/<%= o._id %>" class="btn btn-secondary btn-sm">👁 Xem</a></td>
        </tr>
        <% }) %>
        <% } else { %>
        <tr><td colspan="6" style="text-align:center;padding:35px;color:#999">Không có đơn hàng nào</td></tr>
        <% } %>
        </tbody>
    </table>
    <% if (totalPages > 1) { %>
    <div class="pagination">
        <% if (page > 1) { %><a href="?page=<%= page-1 %>">← Trước</a><% } %>
        <% for (let i = 1; i <= totalPages; i++) { %><% if (i===page){%><span class="current"><%= i %></span><%}else{%><a href="?page=<%= i %>"><%= i %></a><%}%><% } %>
        <% if (page < totalPages) { %><a href="?page=<%= page+1 %>">Tiếp →</a><% } %>
    </div>
    <% } %>
</div>
