<% locals.activePage = 'dashboard' %>

<div class="page-header">
    <h1>📊 Tổng quan hệ thống</h1>
    <span style="color:#999;font-size:14px">Cập nhật: <%= new Date().toLocaleString('vi-VN') %></span>
</div>

<!-- Stats Cards -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:25px">
    <div class="card" style="border-left:4px solid #FFB606;display:flex;align-items:center;gap:18px">
        <span style="font-size:40px">👥</span>
        <div><p style="color:#666;font-size:13px">Khách hàng</p><h2 style="font-size:30px;font-weight:800"><%= stats.totalUsers %></h2></div>
    </div>
    <div class="card" style="border-left:4px solid #28a745;display:flex;align-items:center;gap:18px">
        <span style="font-size:40px">📦</span>
        <div><p style="color:#666;font-size:13px">Sản phẩm hoạt động</p><h2 style="font-size:30px;font-weight:800"><%= stats.totalProducts %></h2></div>
    </div>
    <div class="card" style="border-left:4px solid #17a2b8;display:flex;align-items:center;gap:18px">
        <span style="font-size:40px">🛒</span>
        <div><p style="color:#666;font-size:13px">Tổng đơn hàng</p><h2 style="font-size:30px;font-weight:800"><%= stats.totalOrders %></h2></div>
    </div>
    <div class="card" style="border-left:4px solid #dc3545;display:flex;align-items:center;gap:18px">
        <span style="font-size:40px">💰</span>
        <div><p style="color:#666;font-size:13px">Doanh thu 30 ngày</p><h2 style="font-size:22px;font-weight:800"><%= stats.revenue30Days.toLocaleString('vi-VN') %> ₫</h2></div>
    </div>
</div>

<!-- Order Status Summary -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:25px">
    <div class="card">
        <h3 style="margin-bottom:15px;font-size:16px">📋 Trạng thái đơn hàng</h3>
        <div style="display:flex;flex-direction:column;gap:10px">
            <% const statusConfig = { pending:{label:'Chờ xác nhận',color:'#856404',bg:'#fff3cd'}, confirmed:{label:'Đã xác nhận',color:'#0c5460',bg:'#d1ecf1'}, processing:{label:'Đang xử lý',color:'#155724',bg:'#d4edda'}, shipping:{label:'Đang giao',color:'#004085',bg:'#cce5ff'}, delivered:{label:'Đã giao',color:'#155724',bg:'#d4edda'}, cancelled:{label:'Đã hủy',color:'#721c24',bg:'#f8d7da'} }; %>
            <% Object.entries(statusConfig).forEach(([status, cfg]) => { %>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:<%= cfg.bg %>;border-radius:8px">
                <span style="color:<%= cfg.color %>;font-size:14px;font-weight:600"><%= cfg.label %></span>
                <span style="color:<%= cfg.color %>;font-weight:800;font-size:16px"><%= statusMap[status] || 0 %></span>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- Top Products -->
    <div class="card">
        <h3 style="margin-bottom:15px;font-size:16px">⭐ Sản phẩm bán chạy</h3>
        <% if (topProducts.length) { %>
        <% topProducts.forEach((p, i) => { %>
        <div style="display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid #f0f0f0">
            <span style="font-weight:800;color:#FFB606;font-size:16px;width:22px"><%= i+1 %></span>
            <img src="<%= p.thumbnail||'/assets/Image.png' %>" style="width:38px;height:38px;object-fit:cover;border-radius:6px;background:#f5f5f5" onerror="this.src='/assets/Image.png'">
            <div style="flex:1;min-width:0"><p style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= p.name %></p></div>
            <span style="color:#FFB606;font-weight:700;font-size:13px;white-space:nowrap"><%= p.totalSold %> đã bán</span>
        </div>
        <% }) %>
        <% } else { %><p style="color:#999;text-align:center;padding:20px;font-size:14px">Chưa có dữ liệu</p><% } %>
    </div>
</div>

<!-- Recent Orders -->
<div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px">
        <h3 style="font-size:16px">🕐 Đơn hàng gần nhất</h3>
        <a href="/admin/don-hang" class="btn btn-primary btn-sm">Xem tất cả →</a>
    </div>
    <% if (recentOrders.length) { %>
    <table>
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày đặt</th></tr></thead>
        <tbody>
        <% recentOrders.forEach(o => { %>
        <tr>
            <td><a href="/admin/don-hang/<%= o._id %>" style="color:#FFB606;font-weight:600;text-decoration:none"><%= o.orderCode %></a></td>
            <td><%= o.user ? o.user.fullName : 'N/A' %></td>
            <td style="font-weight:700;color:#FFB606"><%= o.totalAmount.toLocaleString('vi-VN') %>₫</td>
            <td><span class="badge <%= {pending:'badge-warning',confirmed:'badge-info',delivered:'badge-success',cancelled:'badge-danger'}[o.status]||'badge-secondary' %>"><%= {pending:'Chờ xác nhận',confirmed:'Đã xác nhận',processing:'Đang xử lý',shipping:'Đang giao',delivered:'Đã giao',cancelled:'Đã hủy'}[o.status]||o.status %></span></td>
            <td style="font-size:13px;color:#666"><%= new Date(o.createdAt).toLocaleDateString('vi-VN') %></td>
        </tr>
        <% }) %>
        </tbody>
    </table>
    <% } else { %><p style="text-align:center;color:#999;padding:20px;font-size:14px">Chưa có đơn hàng nào</p><% } %>
</div>

<!-- Upcoming Bookings -->
<% if (recentBookings.length) { %>
<div class="card" style="margin-top:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px">
        <h3 style="font-size:16px">📅 Lịch hẹn sắp tới</h3>
        <a href="/admin/lich-hen" class="btn btn-primary btn-sm">Xem tất cả →</a>
    </div>
    <table>
        <thead><tr><th>Mã lịch hẹn</th><th>Khách hàng</th><th>Thú cưng</th><th>Dịch vụ</th><th>Ngày hẹn</th><th>Giờ</th></tr></thead>
        <tbody>
        <% recentBookings.forEach(b => { %>
        <tr>
            <td><span style="font-weight:600;color:#FFB606"><%= b.bookingCode %></span></td>
            <td><%= b.user ? b.user.fullName : 'N/A' %></td>
            <td>🐾 <%= b.pet.name %></td>
            <td style="font-size:13px"><%= b.service %></td>
            <td style="font-size:13px"><%= new Date(b.bookingDate).toLocaleDateString('vi-VN') %></td>
            <td style="font-size:13px"><%= b.timeSlot %></td>
        </tr>
        <% }) %>
        </tbody>
    </table>
</div>
<% } %>
