<!-- ── AUTH POPUP (từ popuploginsignin.html) ── -->
<% if (!currentUser) { %>
<div class="auth-overlay" id="authOverlay" onclick="closeAuthOnOverlay(event)">
    <div class="auth-popup">
        <div class="auth-popup-header">
            <div style="font-size:42px;margin-bottom:8px">🐾</div>
            <h2 id="authPopupTitle">Chào mừng trở lại!</h2>
            <p id="authPopupSub">Đăng nhập để trải nghiệm dịch vụ tốt nhất cho thú cưng</p>
            <button class="auth-close-btn" onclick="closeAuthPopup()">×</button>
        </div>
        <div class="auth-popup-body">
            <!-- Tabs -->
            <div class="auth-tabs">
                <button class="auth-tab-btn active" id="loginTabBtn" onclick="switchAuthTab('login')">Đăng Nhập</button>
                <button class="auth-tab-btn" id="signupTabBtn" onclick="switchAuthTab('signup')">Đăng Ký</button>
            </div>

            <!-- Login Form -->
            <div class="auth-form-content active" id="authLoginForm">
                <form action="/dang-nhap" method="POST">
                    <div class="auth-input-group">
                        <label for="ppLoginEmail">Email</label>
                        <input type="email" id="ppLoginEmail" name="email" placeholder="Nhập email của bạn" required>
                    </div>
                    <div class="auth-input-group">
                        <label for="ppLoginPwd">Mật khẩu</label>
                        <input type="password" id="ppLoginPwd" name="password" placeholder="Nhập mật khẩu" required>
                    </div>
                    <div class="auth-forgot">
                        <a href="/quen-mat-khau">Quên mật khẩu?</a>
                    </div>
                    <button type="submit" class="auth-submit-btn">Đăng Nhập</button>
                </form>
                <div class="auth-divider"><span>Hoặc đăng nhập với</span></div>
                <div class="auth-social-login">
                    <button class="auth-social-btn" onclick="window.location='/auth/google'">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M19.8 10.2273C19.8 9.51819 19.7364 8.83637 19.6182 8.18182H10.2V12.05H15.6109C15.3727 13.3 14.6455 14.3591 13.5636 15.0682V17.5773H16.8182C18.7091 15.8364 19.8 13.2727 19.8 10.2273Z" fill="#4285F4"/><path d="M10.2 20C12.9 20 15.1682 19.1045 16.8182 17.5773L13.5636 15.0682C12.6455 15.6682 11.5091 16.0227 10.2 16.0227C7.59545 16.0227 5.38182 14.2636 4.56364 11.9H1.20909V14.4909C2.84091 17.7591 6.24545 20 10.2 20Z" fill="#34A853"/><path d="M4.56364 11.9C4.36364 11.3 4.24545 10.6591 4.24545 10C4.24545 9.34091 4.36364 8.7 4.56364 8.1V5.50909H1.20909C0.540909 6.85909 0.2 8.38636 0.2 10C0.2 11.6136 0.540909 13.1409 1.20909 14.4909L4.56364 11.9Z" fill="#FBBC05"/><path d="M10.2 3.97727C11.6318 3.97727 12.9136 4.48182 13.9227 5.43636L16.8091 2.55C15.1636 1.03636 12.8955 0 10.2 0C6.24545 0 2.84091 2.24091 1.20909 5.50909L4.56364 8.1C5.38182 5.73636 7.59545 3.97727 10.2 3.97727Z" fill="#EA4335"/></svg>
                        Google
                    </button>
                    <button class="auth-social-btn" onclick="window.location='/auth/facebook'">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M20 10C20 4.47715 15.5228 0 10 0C4.47715 0 0 4.47715 0 10C0 14.9912 3.65684 19.1283 8.4375 19.8785V12.8906H5.89844V10H8.4375V7.79688C8.4375 5.29063 9.93047 3.90625 12.2146 3.90625C13.3084 3.90625 14.4531 4.10156 14.4531 4.10156V6.5625H13.1922C11.95 6.5625 11.5625 7.3334 11.5625 8.125V10H14.3359L13.8926 12.8906H11.5625V19.8785C16.3432 19.1283 20 14.9912 20 10Z" fill="#1877F2"/></svg>
