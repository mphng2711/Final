<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Admin - PurePaw' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',Arial,sans-serif; }
        body { background:#f4f6f9; display:flex; flex-direction:column; min-height:100vh; }
        /* Topbar */
        .admin-topbar { height:54px; background:linear-gradient(135deg,#FFE002,#FFB606); display:flex; align-items:center; padding:0 20px; position:sticky; top:0; z-index:1000; box-shadow:0 2px 8px rgba(0,0,0,.15); }
        .admin-topbar .brand { font-weight:700; font-size:17px; color:#1C1C1C; display:flex; align-items:center; gap:8px; text-decoration:none; margin-right:auto; }
        .admin-topbar .topbar-right { display:flex; align-items:center; gap:15px; font-size:14px; color:#1C1C1C; }
        .admin-topbar .topbar-right a { color:#1C1C1C; text-decoration:none; font-weight:600; }
        /* Layout */
        .admin-wrapper { display:flex; flex:1; }
        /* Sidebar */
        .admin-sidebar { width:230px; background:#fff; border-right:1px solid #e9ecef; min-height:calc(100vh - 54px); }
        .sidebar-nav { padding:15px 0; }
        .sidebar-section { padding:8px 15px 5px; font-size:11px; font-weight:700; text-transform:uppercase; color:#999; letter-spacing:.8px; }
        .sidebar-nav a { display:flex; align-items:center; gap:10px; padding:11px 20px; color:#555; text-decoration:none; font-size:14px; transition:all .2s; border-left:3px solid transparent; }
        .sidebar-nav a:hover, .sidebar-nav a.active { background:#fffbeb; color:#1C1C1C; border-left-color:#FFB606; font-weight:600; }
        .sidebar-nav a i { width:18px; text-align:center; font-size:15px; }
        /* Content */
        .admin-content { flex:1; padding:25px; overflow-x:auto; }
        /* Flash */
        .flash-msg { padding:12px 18px; border-radius:6px; margin-bottom:15px; font-size:14px; display:flex; align-items:center; gap:10px; }
        .flash-success { background:#d4edda; color:#155724; border-left:4px solid #28a745; }
        .flash-error { background:#f8d7da; color:#721c24; border-left:4px solid #dc3545; }
        /* Common Admin UI */
        .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
        .page-header h1 { font-size:22px; color:#1C1C1C; }
        .btn { padding:9px 18px; border-radius:6px; border:none; cursor:pointer; font-size:14px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all .2s; }
        .btn-primary { background:#FFE002; color:#1C1C1C; }
        .btn-primary:hover { background:#FFB606; }
        .btn-danger { background:#dc3545; color:#fff; }
        .btn-danger:hover { background:#c82333; }
        .btn-secondary { background:#6c757d; color:#fff; }
        .btn-secondary:hover { background:#5a6268; }
        .btn-sm { padding:6px 12px; font-size:13px; }
        .btn-success { background:#28a745; color:#fff; }
        .btn-success:hover { background:#218838; }
        .card { background:#fff; border-radius:8px; box-shadow:0 1px 4px rgba(0,0,0,.08); padding:20px; margin-bottom:20px; }
        table { width:100%; border-collapse:collapse; }
        table th { background:#f8f9fa; padding:10px 14px; text-align:left; font-size:13px; color:#555; border-bottom:2px solid #e9ecef; }
        table td { padding:10px 14px; font-size:14px; border-bottom:1px solid #f0f0f0; vertical-align:middle; }
        table tr:hover { background:#fffbeb; }
        .badge { padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; }
        .badge-success { background:#d4edda; color:#155724; }
        .badge-warning { background:#fff3cd; color:#856404; }
        .badge-danger { background:#f8d7da; color:#721c24; }
        .badge-info { background:#d1ecf1; color:#0c5460; }
        .badge-secondary { background:#e2e3e5; color:#383d41; }
        .form-group { margin-bottom:18px; }
        .form-group label { display:block; font-size:14px; font-weight:600; margin-bottom:6px; color:#333; }
        .form-control { width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:6px; font-size:14px; transition:border .2s; }
        .form-control:focus { outline:none; border-color:#FFB606; box-shadow:0 0 0 3px rgba(255,182,6,.15); }
        .form-check { display:flex; align-items:center; gap:8px; }
        .pagination { display:flex; gap:6px; align-items:center; margin-top:20px; flex-wrap:wrap; }
        .pagination a, .pagination span { padding:6px 12px; border-radius:6px; text-decoration:none; font-size:14px; }
        .pagination a { background:#fff; border:1px solid #ddd; color:#555; transition:all .2s; }
        .pagination a:hover { background:#fffbeb; border-color:#FFB606; }
        .pagination .current { background:#FFE002; color:#1C1C1C; font-weight:700; }
    </style>
    <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body>
<header class="admin-topbar">
    <a href="/admin" class="brand">🐾 PurePaw Admin</a>
    <div class="topbar-right">
        <span><i class="fas fa-user"></i> <%= currentUser ? currentUser.fullName : 'Admin' %></span>
        <a href="/"><i class="fas fa-home"></i> Trang chủ</a>
        <a href="/dang-xuat"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
    </div>
</header>

<div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <nav class="sidebar-nav">
            <div class="sidebar-section">Tổng quan</div>
            <a href="/admin" class="<%= typeof activePage !== 'undefined' && activePage==='dashboard' ? 'active' : '' %>">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <div class="sidebar-section">Quản lý</div>
            <a href="/admin/san-pham" class="<%= typeof activePage !== 'undefined' && activePage==='products' ? 'active' : '' %>">
                <i class="fas fa-box"></i> Sản phẩm
            </a>
            <a href="/admin/danh-muc" class="<%= typeof activePage !== 'undefined' && activePage==='categories' ? 'active' : '' %>">
                <i class="fas fa-tags"></i> Danh mục
            </a>
            <a href="/admin/don-hang" class="<%= typeof activePage !== 'undefined' && activePage==='orders' ? 'active' : '' %>">
                <i class="fas fa-shopping-cart"></i> Đơn hàng
            </a>
            <a href="/admin/lich-hen" class="<%= typeof activePage !== 'undefined' && activePage==='bookings' ? 'active' : '' %>">
                <i class="fas fa-calendar-check"></i> Lịch hẹn Spa
            </a>
            <a href="/admin/nguoi-dung" class="<%= typeof activePage !== 'undefined' && activePage==='users' ? 'active' : '' %>">
                <i class="fas fa-users"></i> Người dùng
            </a>
            <div class="sidebar-section">Nội dung & Marketing</div>
            <a href="/admin/bai-viet" class="<%= typeof activePage !== 'undefined' && activePage==='blogs' ? 'active' : '' %>">
                <i class="fas fa-newspaper"></i> Bài viết
            </a>
            <a href="/admin/danh-gia" class="<%= typeof activePage !== 'undefined' && activePage==='reviews' ? 'active' : '' %>">
                <i class="fas fa-star"></i> Đánh giá
            </a>
            <a href="/admin/coupon" class="<%= typeof activePage !== 'undefined' && activePage==='coupons' ? 'active' : '' %>">
                <i class="fas fa-ticket-alt"></i> Mã giảm giá
            </a>
            <a href="/admin/faq" class="<%= typeof activePage !== 'undefined' && activePage==='faqs' ? 'active' : '' %>">
                <i class="fas fa-question-circle"></i> FAQ
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
        <% if (success && success.length) { %><div class="flash-msg flash-success"><i class="fas fa-check-circle"></i> <%- success[0] %></div><% } %>
        <% if (error && error.length) { %><div class="flash-msg flash-error"><i class="fas fa-exclamation-circle"></i> <%- error[0] %></div><% } %>
        <%- body %>
    </main>
</div>

<script>
    setTimeout(() => { document.querySelectorAll('.flash-msg').forEach(el => el.style.display='none'); }, 5000);
</script>
<%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
