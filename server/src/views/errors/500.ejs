<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 - Lỗi máy chủ | PurePaw</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Segoe UI',sans-serif; background:#f5f7fa; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:40px 20px; }
        .emoji { font-size:80px; margin-bottom:20px; }
        .code { font-size:80px; font-weight:900; color:#dc3545; line-height:1; }
        h2 { font-size:24px; color:#1C1C1C; margin:12px 0; }
        p { color:#666; font-size:16px; max-width:450px; margin-bottom:30px; }
        .btn-primary { padding:12px 28px; background:linear-gradient(135deg,#FFE002,#FFB606); border-radius:10px; text-decoration:none; color:#1C1C1C; font-weight:700; }
    </style>
</head>
<body>
    <div class="emoji">⚠️</div>
    <div class="code">500</div>
    <h2>Lỗi máy chủ</h2>
    <p><%= typeof message !== 'undefined' ? message : 'Có lỗi không mong muốn xảy ra. Vui lòng thử lại sau.' %></p>
    <a href="/" class="btn-primary">🏠 Về trang chủ</a>
</body>
</html>
