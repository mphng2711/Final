    </div>
</div>

<!-- Booking Modal — POST thật tới /grooming/dat-lich -->
<div class="booking-overlay" id="bookingOverlay"
     data-logged="<%= currentUser ? '1' : '0' %>"
     onclick="if(event.target===this)closeBooking()">
    <div class="booking-box">
        <button class="booking-close" onclick="closeBooking()">✕</button>
        <div class="booking-tag">✦ <span id="bookingServiceName">Dịch vụ</span></div>
        <h2>Đặt lịch ngay</h2>

        <form class="booking-form" method="POST" action="/grooming/dat-lich" id="bookingForm">
            <!-- serviceId hidden — được set bởi JS khi click nút đặt lịch -->
            <input type="hidden" name="serviceId" id="bookingServiceId">

            <!-- Thông tin thú cưng -->
            <div class="bfield">
                <label>Tên thú cưng *</label>
                <input type="text" name="petName" placeholder="Tên bé (VD: Mochi, Bông...)" required>
            </div>

            <div class="bfield-row">
                <div class="bfield">
                    <label>Loài thú cưng *</label>
                    <select name="petSpecies" required>
                        <option value="">Chọn loài...</option>
                        <option value="dog">🐶 Chó</option>
                        <option value="cat">🐱 Mèo</option>
                        <option value="other">🐰 Khác</option>
                    </select>
                </div>
                <div class="bfield">
                    <label>Giống (tùy chọn)</label>
                    <input type="text" name="petBreed" placeholder="VD: Poodle, Munchkin...">
                </div>
            </div>

            <div class="bfield">
                <label>Cân nặng (kg, tùy chọn)</label>
                <input type="number" name="petWeight" placeholder="VD: 3.5" min="0.1" max="100" step="0.1">
            </div>

            <!-- Thời gian -->
            <div class="bfield-row">
                <div class="bfield">
                    <label>Ngày hẹn *</label>
                    <input type="date" name="bookingDate" id="bookingDate" required
                           min="<%= new Date(Date.now()+86400000).toISOString().split('T')[0] %>">
                </div>
                <div class="bfield">
                    <label>Khung giờ *</label>
                    <select name="timeSlot" required>
                        <option value="">Chọn giờ...</option>
                        <% timeSlots.forEach(slot => { %>
                        <option value="<%= slot %>"><%= slot %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <!-- Ghi chú -->
            <div class="bfield">
                <label>Ghi chú đặc biệt</label>
                <textarea name="note" placeholder="Tình trạng sức khỏe, yêu cầu đặc biệt..." rows="2" style="resize:vertical"></textarea>
            </div>

            <button type="submit" class="btn-submit-booking">
                🐾 Xác nhận đặt lịch
            </button>
        </form>
    </div>
</div>

<script>
// Bản đồ serviceId tương ứng mỗi nút đặt lịch
var _serviceMap = {
    'Tắm & Sấy khô':                       'bath',
    'Cắt tỉa lông':                         'grooming',
    'Combo Spa (Tắm + Cắt + Vệ sinh tai)':  'combo',
    'Kiểm tra sức khỏe tổng quát':          'health_check',
    'Gói Basic':                            'combo',
    'Gói Advanced':                         'combo',
};

function openBooking(serviceName, serviceId) {
    // Kiểm tra đăng nhập qua data-attribute trên element
    var isLogged = document.getElementById('bookingOverlay').dataset.logged === '1';
    if (!isLogged) {
        alert('Vui lòng đăng nhập để đặt lịch!');
        window.location.href = '/dang-nhap?next=/grooming';
        return;
    }
    var sid = serviceId || _serviceMap[serviceName] || 'bath';
    document.getElementById('bookingServiceName').textContent = serviceName || 'Dịch vụ';
    document.getElementById('bookingServiceId').value = sid;
    document.getElementById('bookingOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeBooking() {
    document.getElementById('bookingOverlay').classList.remove('open');
    document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeBooking();
});
</script>



