
<style>
.blog-hero { background: linear-gradient(135deg,#fffbeb,#fff3cd); padding: 40px 0; }
.blog-detail-wrap { max-width: 820px; margin: 0 auto; padding: 40px 20px; }
.blog-content { background: #fff; border-radius: 14px; padding: 35px; box-shadow: 0 2px 10px rgba(0,0,0,.06); line-height: 1.9; font-size: 16px; color: #444; }
.blog-content h2, .blog-content h3 { color: #1C1C1C; margin: 24px 0 12px; }
.blog-content img { max-width: 100%; border-radius: 10px; margin: 16px 0; }
.blog-content p { margin-bottom: 16px; }
.related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin: 20px 0 50px; }
.related-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.06); text-decoration: none; color: inherit; transition: all .3s; display: block; }
.related-card:hover { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,0,0,.1); }
</style>

<div class="blog-hero">
  <div class="wrap-content">
    <p style="color:#999;font-size:14px;margin-bottom:12px">
      <a href="/" style="color:#999;text-decoration:none">Trang chủ</a> ›
      <a href="/tin-tuc" style="color:#999;text-decoration:none">Tin tức</a> ›
      <span style="color:#FFB606"><%= categoryLabels[blog.category] || blog.category %></span>
    </p>
    <h1 style="font-size:30px;color:#1C1C1C;max-width:800px;line-height:1.4;margin-bottom:15px"><%= blog.title %></h1>
    <div style="display:flex;gap:20px;flex-wrap:wrap;font-size:14px;color:#666">
      <span>✍️ <%= blog.author ? blog.author.fullName : 'PurePaw' %></span>
      <span>📅 <%= new Date(blog.publishedAt).toLocaleDateString('vi-VN', {year:'numeric',month:'long',day:'numeric'}) %></span>
      <span>👁 <%= blog.viewCount %> lượt xem</span>
      <span class="blog-cat" style="background:#FFE002;color:#1C1C1C;padding:2px 12px;border-radius:20px;font-weight:700">
        <%= categoryLabels[blog.category] || blog.category %>
      </span>
    </div>
  </div>
</div>

<div class="blog-detail-wrap">
  <!-- Ảnh đại diện -->
  <img src="<%= blog.thumbnail %>" alt="<%= blog.title %>"
       style="width:100%;height:380px;object-fit:cover;border-radius:14px;margin-bottom:25px"
       onerror="this.style.display='none'">

  <!-- Nội dung -->
  <div class="blog-content">
    <% if (blog.excerpt) { %>
    <p style="font-size:17px;font-weight:500;color:#555;border-left:4px solid #FFB606;padding-left:16px;margin-bottom:24px;font-style:italic">
      <%= blog.excerpt %>
    </p>
    <% } %>
    <%- blog.content %>
  </div>

  <!-- Tags -->
  <% if (blog.tags && blog.tags.length) { %>
  <div style="margin-top:20px;display:flex;gap:8px;flex-wrap:wrap">
    <% blog.tags.forEach(tag => { %>
    <span style="padding:5px 14px;background:#f0f0f0;border-radius:20px;font-size:13px;color:#555">#<%= tag %></span>
    <% }) %>
  </div>
  <% } %>

  <!-- Nút chia sẻ -->
  <div style="margin:25px 0;display:flex;gap:12px;flex-wrap:wrap">
    <a href="/tin-tuc" style="padding:11px 22px;border:2px solid #e0e0e0;border-radius:8px;text-decoration:none;color:#555;font-weight:600;font-size:14px">← Quay lại danh sách</a>
  </div>

  <!-- Bài viết liên quan -->
  <% if (related && related.length) { %>
  <h2 style="font-size:22px;margin-bottom:18px;color:#1C1C1C">📌 Bài viết liên quan</h2>
  <div class="related-grid">
    <% related.forEach(r => { %>
    <a href="/tin-tuc/<%= r.slug %>" class="related-card">
      <img src="<%= r.thumbnail || '/assets/Image.png' %>" alt="<%= r.title %>"
           style="width:100%;height:130px;object-fit:cover" onerror="this.src='/assets/Image.png'">
      <div style="padding:12px">
        <p style="font-size:13px;font-weight:600;line-height:1.5;color:#1C1C1C"><%= r.title %></p>
        <p style="font-size:12px;color:#999;margin-top:6px">📅 <%= new Date(r.publishedAt).toLocaleDateString('vi-VN') %></p>
      </div>
    </a>
    <% }) %>
  </div>
  <% } %>
</div>
