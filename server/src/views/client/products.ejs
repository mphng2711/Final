
<style>
/* ══════════════════════════════════════════════════════
   PRODUCTS PAGE — clone y hệt product.html backup
   ══════════════════════════════════════════════════════ */

/* Breadcrumb */
.breadCrumbs {
    background: #ffffff;
    padding: 15px 0;
    margin-bottom: 30px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}
.breadcrumb { list-style: none; display: flex; gap: 10px; margin: 0; padding: 0; }
.breadcrumb-item { color: #666; }
.breadcrumb-item a { color: #666; text-decoration: none; transition: color .3s; }
.breadcrumb-item a:hover { color: #FFB606; }
.breadcrumb-item.active a { color: #1C1C1C; font-weight: 600; }
.breadcrumb-item + .breadcrumb-item::before { content: "›"; margin-right: 10px; color: #999; }

/* Page Title — giống hệt backup */
.title-detail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding: 25px;
    background: #ffffff;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}
.title-detail h1 {
    color: #1C1C1C;
    font-size: 32px;
    font-weight: 700;
    margin: 0;
}
.filter {
    background: linear-gradient(135deg, #FFE002 0%, #FFB606 100%);
    padding: 10px 20px;
    border-radius: 10px;
    color: #1C1C1C;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}
.filter:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255,182,6,.4); }
.filter select {
    background: transparent; border: none;
    color: #1C1C1C; font-weight: 600; font-size: 16px;
    cursor: pointer; outline: none;
}

/* Filter Bar */
.filter-bar {
    background: #fff; border-radius: 12px;
    padding: 18px 22px; margin-bottom: 28px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
}
.filter-bar form { display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end; }
.filter-group { display: flex; flex-direction: column; gap: 5px; }
.filter-group label { font-size: 12px; font-weight: 700; color: #777; text-transform: uppercase; letter-spacing: .5px; }
.filter-select {
    padding: 9px 14px; border: 2px solid #e0e0e0; border-radius: 8px;
    font-size: 14px; background: #f9f9f9; cursor: pointer; transition: border .2s;
}
.filter-select:focus { outline: none; border-color: #FFE002; }
.filter-input {
    padding: 9px 14px; border: 2px solid #e0e0e0; border-radius: 8px;
    font-size: 14px; min-width: 200px; transition: border .2s;
}
.filter-input:focus { outline: none; border-color: #FFE002; }
.filter-btn {
    padding: 10px 22px; background: linear-gradient(135deg,#FFE002,#FFB606);
    border: none; border-radius: 8px; font-weight: 700; cursor: pointer;
    font-size: 14px; color: #1C1C1C; transition: all .2s;
    display: flex; align-items: center; gap: 6px;
}
.filter-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(255,182,6,.3); }
.btn-clear-filter {
    padding: 10px 16px; border: 2px solid #ddd; border-radius: 8px;
    text-decoration: none; color: #666; font-size: 14px;
    display: flex; align-items: center; transition: all .2s;
}
.btn-clear-filter:hover { border-color: #999; color: #333; }

/* Results info */
.results-info { color: #666; font-size: 14px; margin-bottom: 18px; }

/* ═══ PRODUCT GRID — clone y hệt product.html ═══ */
.grid-product {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
    margin-bottom: 40px;
}

.product {
    background: #ffffff;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
}
.product:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(255,182,6,0.3);
}

/* Ảnh sản phẩm — CLONE Y HỆT product.html */
.pic-product {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #fffbeb 0%, #fff9e6 100%);
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 3px solid #FFE002;
}
.pic-product img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.4s ease;
}
.product:hover .pic-product img {
    transform: scale(1.1);
}

/* Badges */
.badge-featured {
    position: absolute; top: 12px; left: 12px;
    background: linear-gradient(135deg, #FFE002, #FFB606);
    color: #1C1C1C; padding: 4px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 700; z-index: 2;
}
.badge-sale {
    position: absolute; top: 12px; right: 12px;
    background: #e74c3c; color: #fff;
    padding: 4px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 700; z-index: 2;
}

/* Info — clone y hệt product.html */
.info-product {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.cat-tag {
    font-size: 12px; color: #FFB606; font-weight: 700;
    text-transform: uppercase; letter-spacing: .5px;
}
.name-product {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
}
.name-product a {
    color: #1C1C1C;
    text-decoration: none;
    transition: all 0.3s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.name-product a:hover { color: #FFB606; }

.price-product {
    margin: 0;
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}
.price-new {
    background: linear-gradient(135deg, #FFE002 0%, #FFB606 100%);
    color: #1C1C1C;
    font-weight: 700;
    font-size: 16px;
    padding: 8px 15px;
    border-radius: 8px;
    display: inline-block;
}
.price-old {
    color: #999;
    text-decoration: line-through;
    font-size: 14px;
}
.product-rating { font-size: 13px; color: #666; }

/* Nút xem chi tiết */
.btn-detail {
    display: block;
    text-align: center;
    padding: 12px;
    background: #1C1C1C;
    color: #FFE002;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    transition: all 0.3s ease;
}
.btn-detail:hover {
    background: #FFE002;
    color: #1C1C1C;
    transform: translateY(-2px);
}

/* Pagination — clone y hệt product.html */
.pagination {
    display: flex; gap: 10px; list-style: none;
    padding: 0; margin: 30px 0; justify-content: center; flex-wrap: wrap;
}
.page-item { margin: 0; }
.page-link {
    padding: 10px 15px; border-radius: 8px;
    background: #ffffff; color: #1C1C1C;
    text-decoration: none; font-weight: 600;
    transition: all 0.3s ease; display: block;
    border: 2px solid #e0e0e0;
}
.page-item.active .page-link {
    background: linear-gradient(135deg, #FFE002 0%, #FFB606 100%);
    border-color: #FFB606;
}
.page-item.disabled .page-link { opacity: .5; cursor: not-allowed; }
.page-link:hover:not(.page-item.disabled .page-link) {
    background: linear-gradient(135deg, #FFE002 0%, #FFB606 100%);
    border-color: #FFB606;
    transform: translateY(-2px);
}

/* Responsive */
@media (max-width: 1024px) {
    .grid-product { grid-template-columns: repeat(auto-fill, minmax(250px,1fr)); }
}
@media (max-width: 768px) {
    .title-detail { flex-direction: column; gap: 15px; text-align: center; }
    .title-detail h1 { font-size: 24px; }
    .grid-product { grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 15px; }
    .pic-product { height: 240px; }
}
@media (max-width: 480px) {
    .grid-product { grid-template-columns: repeat(2,1fr); gap: 10px; }
    .pic-product { height: 180px; }
    .info-product { padding: 12px; gap: 8px; }
    .name-product { font-size: 13px; }
    .price-new { font-size: 13px; padding: 6px 10px; }
    .btn-detail { font-size: 12px; padding: 9px; }
}
</style>

<!-- Breadcrumb -->
<div class="breadCrumbs">
    <div class="wrap-content">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item active"><a href="/san-pham">Sản phẩm</a></li>
        </ul>
    </div>
</div>

<div class="wrap-content" style="padding-bottom:60px">
    <!-- Page Title + Sort -->
    <div class="title-detail">
        <h1>Sản phẩm</h1>
        <div class="filter">
            <select id="sortSelect" onchange="doSort(this.value)">
                <option value="">Thức ăn &amp; Dinh dưỡng</option>
                <option value="price-asc" <%= query && query.sort==='price-asc'?'selected':'' %>>Giá tăng dần</option>
                <option value="price-desc" <%= query && query.sort==='price-desc'?'selected':'' %>>Giá giảm dần</option>
                <option value="popular" <%= query && query.sort==='popular'?'selected':'' %>>Bán chạy</option>
                <option value="new" <%= query && query.sort==='new'?'selected':'' %>>Mới nhất</option>
            </select>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <form method="GET" action="/san-pham">
            <div class="filter-group">
                <label>Tìm kiếm</label>
                <input type="text" name="search" class="filter-input"
                    placeholder="Tên sản phẩm..."
                    value="<%= query && query.search ? query.search : '' %>">
            </div>
            <div class="filter-group">
                <label>Danh mục</label>
                <select name="category" class="filter-select">
                    <option value="">Tất cả danh mục</option>
                    <% if (categories) categories.forEach(cat => { %>
                    <option value="<%= cat.slug %>" <%= query && query.category===cat.slug?'selected':'' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="filter-group">
                <label>Thú cưng</label>
                <select name="petType" class="filter-select">
                    <option value="">Tất cả</option>
                    <option value="dog" <%= query && query.petType==='dog'?'selected':'' %>>🐶 Chó</option>
                    <option value="cat" <%= query && query.petType==='cat'?'selected':'' %>>🐱 Mèo</option>
                    <option value="other" <%= query && query.petType==='other'?'selected':'' %>>🐹 Khác</option>
                </select>
            </div>
            <button type="submit" class="filter-btn">
                <i class="fas fa-search"></i> Lọc
            </button>
            <a href="/san-pham" class="btn-clear-filter">Xóa lọc</a>
        </form>
    </div>

    <p class="results-info">Tìm thấy <strong><%= total %></strong> sản phẩm</p>

    <!-- ═══ Products Grid ═══ -->
    <% if (products && products.length) { %>
    <div class="grid-product">
        <% products.forEach(p => { %>
        <div class="product">
            <!-- Ảnh sản phẩm -->
            <div class="pic-product">
                <a href="/san-pham/<%= p.slug %>">
                    <img src="<%= p.thumbnail %>"
                         alt="<%= p.name %>"
                         onerror="this.onerror=null;this.src='https://lapaw.vn/wp-content/uploads/2023/12/pate-meo-lapaw-thit-bo-va-ga-375gr-300x300.jpg'"
                         loading="lazy">
                </a>
                <% if (p.isFeatured) { %>
                <span class="badge-featured">⭐ Nổi bật</span>
                <% } %>
                <% if (p.variants && p.variants[0] && p.variants[0].salePrice) { %>
                <span class="badge-sale">SALE</span>
                <% } %>
            </div>

            <!-- Thông tin sản phẩm -->
            <div class="info-product">
                <% if (p.category) { %>
                <span class="cat-tag">🏷 <%= p.category.name %></span>
                <% } %>

                <h3 class="name-product">
                    <a href="/san-pham/<%= p.slug %>"><%= p.name %></a>
                </h3>

                <% if (p.averageRating > 0) { %>
                <div class="product-rating">
                    <% for(let s=1;s<=5;s++) { %><span style="color:<%= s<=Math.round(p.averageRating)?'#FFB606':'#ddd' %>">★</span><% } %>
                    (<%= p.totalReviews %>)
                </div>
                <% } %>

                <p class="price-product">
                    <% if (p.variants && p.variants[0]) { %>
                    <span class="price-new"><%= (p.variants[0].salePrice || p.variants[0].price).toLocaleString('vi-VN') %>đ</span>
                    <% if (p.variants[0].salePrice) { %>
                    <span class="price-old"><%= p.variants[0].price.toLocaleString('vi-VN') %>đ</span>
                    <% } %>
                    <% } %>
                </p>

                <a href="/san-pham/<%= p.slug %>" class="btn-detail">Xem chi tiết →</a>
            </div>
        </div>
        <% }) %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <ul class="pagination">
        <% if (page > 1) { %>
        <li class="page-item">
            <a class="page-link" href="?<%= new URLSearchParams({...query, page: page-1}).toString() %>">← Trước</a>
        </li>
        <% } else { %>
        <li class="page-item disabled"><span class="page-link">← Trước</span></li>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i===page?'active':'' %>">
            <% if (i===page) { %>
            <span class="page-link"><%= i %></span>
            <% } else { %>
            <a class="page-link" href="?<%= new URLSearchParams({...query, page: i}).toString() %>"><%= i %></a>
            <% } %>
        </li>
        <% } %>

        <% if (page < totalPages) { %>
        <li class="page-item">
            <a class="page-link" href="?<%= new URLSearchParams({...query, page: page+1}).toString() %>">Tiếp →</a>
        </li>
        <% } else { %>
        <li class="page-item disabled"><span class="page-link">Tiếp →</span></li>
        <% } %>
    </ul>
    <% } %>

    <% } else { %>
    <!-- Không tìm thấy -->
    <div style="text-align:center;padding:80px 20px;color:#999">
        <div style="font-size:70px;margin-bottom:20px">🔍</div>
        <h3 style="font-size:22px;margin-bottom:12px;color:#555">Không tìm thấy sản phẩm</h3>
        <p style="margin-bottom:25px">Hãy thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
        <a href="/san-pham" style="padding:12px 28px;background:linear-gradient(135deg,#FFE002,#FFB606);color:#1C1C1C;border-radius:10px;text-decoration:none;font-weight:700">Xem tất cả sản phẩm</a>
    </div>
    <% } %>
</div>

<script>
function doSort(val) {
    const url = new URL(window.location.href);
    if (val) url.searchParams.set('sort', val);
    else url.searchParams.delete('sort');
    window.location.href = url.toString();
}
</script>
