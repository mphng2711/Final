.thankyou-popup h3 { font-size: 2rem; color: #1C1C1C; margin-bottom: 14px; }
.thankyou-popup p { font-size: 1.05rem; color: #3B3B3B; }

@media (max-width: 1024px) {
    .row-1, .row-2 { grid-template-columns: 1fr; gap: 50px; }
