    transform: scale(.85); opacity: 0; transition: all .3s;
    position: relative;
}
.popup-overlay.show .thankyou-popup { transform: scale(1); opacity: 1; }
.thankyou-popup::before {
    content: '✓'; display: block; width: 80px; height: 80px;
    background: #FFE002; color: #1C1C1C; font-size: 3rem; line-height: 80px;
    border-radius: 50%; margin: 0 auto 28px;
