.accordion-button:hover .accordion-icon { background: #FFB606; border-color: #FFB606; color: #fff; transform: rotate(90deg); }
.accordion-item.active .accordion-icon { transform: rotate(45deg); background: #FFE002; border-color: #FFE002; color: #1C1C1C; }
.accordion-content { max-height: 0; overflow: hidden; transition: max-height .35s ease; }
.accordion-item.active .accordion-content { max-height: 300px; padding-bottom: 22px; }
.accordion-content p { font-size: 1rem; color: #3B3B3B; line-height: 1.8; }

/* Map */
