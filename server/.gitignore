# ─── Dependencies ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Build output ────────────────────────────────────────────
dist/
build/

# ─── Environment variables (BẮT BUỘC không commit) ───────────
.env
.env.local
.env.production
.env.staging
# Giữ lại template để người khác biết cần điền gì
!.env.example

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
server.log
server_startup.log

# ─── Uploads (ảnh do người dùng tải lên) ─────────────────────
public/uploads/
# Giữ lại cấu trúc thư mục bằng .gitkeep
!public/uploads/.gitkeep
!public/uploads/products/.gitkeep
!public/uploads/blogs/.gitkeep

# ─── OS files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ─── IDE & Editor ────────────────────────────────────────────
.vscode/settings.json
.vscode/.ropeproject
.idea/
*.swp
*.swo
*~

# ─── TypeScript cache ────────────────────────────────────────
*.tsbuildinfo

# ─── Testing ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────────────────────
*.pem
.cache/
tmp/
temp/
